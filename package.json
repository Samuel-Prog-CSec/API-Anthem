{
  "name": "anthem-api-rest",
  "version": "0.1.0",
  "description": "REST API con Node.js, Express.js, MongoDB y JWT para la gestión de datos urbanos en una ciudad inteligente.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "import:data": "node scripts/importAll.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:src": "eslint src/",
    "lint:scripts": "eslint scripts/",
    "lint:report": "eslint . --format html --output-file reports/eslint-report.html",
    "quality:check": "node scripts/check-code-quality.js",
    "security:check-&-fix": "npm audit && npm audit fix",
    "deps:update": "npx npm-check-updates -t minor -u && npm install",
    "deps:analyze": "npx npm-check-updates && npx depcheck && npm outdated",
    "analyze": "node scripts/analyze.js",
    "profile:doctor": "clinic doctor -- node src/server.js",
    "profile:flame": "clinic flame -- node src/server.js",
    "profile:heap": "clinic heapprofiler -- node src/server.js",
    "profile:all": "npm run profile:doctor && npm run profile:flame && npm run profile:heap"
  },
  "keywords": [
    "NodeJS",
    "Express",
    "mongoose",
    "rest-api",
    "authentication",
    "jwt",
    "CORS",
    "rate-limiting",
    "smart-city",
    "MongoDB-Atlas",
    "PinoJS"
  ],
  "author": "Samuel Blanchart Pérez",
  "license": "",
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.1",
    "node-cache": "^5.1.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
