# Environment Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000/api/v1

# Database Configuration
# IMPORTANTE: usar 127.0.0.1 (IPv4 explicito) y NUNCA `localhost`.
# En Windows con MongoDB nativo + Docker presentes, `localhost` se resuelve
# en IPv6 (::1) o `host.docker.internal` segun el entorno y puede acabar
# conectando al contenedor en lugar del MongoDB local. Sintoma: la app ve
# la BD vacia mientras MongoDB Compass (que usa 127.0.0.1) si ve los datos.
DATABASE_URI=mongodb://127.0.0.1:27017/Anthem

# JWT Configuration
# IMPORTANTE: JWT_SECRET y JWT_REFRESH_SECRET DEBEN ser:
#   - Diferentes entre si (compromiso de uno no compromete el otro)
#   - Minimo 32 caracteres en desarrollo, 64+ en produccion
#   - Aleatoriedad criptografica (NUNCA frases predecibles)
#
# Generar secretos seguros (cualquiera de las dos):
#   node:   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl: openssl rand -hex 64
#
# Los tokens emitidos incluyen `jti` (UUID v4) para permitir revocacion
# individual via TokenBlacklist sin almacenar el JWT completo.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-characters-long
JWT_REFRESH_SECRET=your-different-super-secret-refresh-token-key-min-32-chars-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=15d

# Security Configuration
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
# Comma-separated list of allowed origins
# Use specific origins in production, never use '*' with credentials
# Supports wildcard subdomains: *.example.com
# Examples:
#   - Development: http://localhost:3000,http://localhost:3001
#   - Production: https://app.example.com,https://admin.example.com
#   - Wildcard subdomain: https://*.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# API Configuration
API_TIMEOUT=30000

# Logging Configuration
# LOG_LEVEL: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug
# Threshold in milliseconds for slow operation warnings
SLOW_OPERATION_THRESHOLD=3000

# Database Pool Configuration
DB_MAX_POOL_SIZE=15
DB_TIMEOUT=5000

# Test Mode Configuration
# TEST_MODE: true para habilitar modo de prueba y reducir la validación de tokens, false para deshabilitarlo 
# En producción debe ser SIEMPRE false
TEST_MODE=true
# Opcional: definir clave propia, por defecto es 'dev-testing-key-123'
TEST_BYPASS_KEY=dev-testing-key-123